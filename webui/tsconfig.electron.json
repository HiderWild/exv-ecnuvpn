{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist-electron",
    "rootDir": ".",
    "strict": true,
    "types": ["node", "electron"],
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["desktop/**/*.ts", "host/**/*.ts"],
  "exclude": ["desktop/**/*sync-conflict*.ts", "host/**/*sync-conflict*.ts"]
}

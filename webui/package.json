{
  "name": "webui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"const ua = process.env.npm_config_user_agent || ''; if (!ua.startsWith('pnpm/')) { console.error('Use pnpm instead of npm for this project.'); process.exit(1); }\"",
    "dev": "vite",
    "dev:desktop": "vite --port 8288 --strictPort",
    "desktop:dev": "npm-run-all --parallel dev:desktop electron:dev electron:start",
    "electron:dev": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "electron:start": "wait-on http://localhost:8288 dist-electron/main/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:8288 electron dist-electron/main/index.js",
    "build": "vue-tsc -b && vite build",
    "build:electron": "node scripts/build-electron.cjs",
    "prepare:native": "node scripts/prepare-native.cjs",
    "desktop:compile": "pnpm run build && pnpm run build:electron && pnpm run prepare:native",
    "desktop:package": "electron-builder --config electron-builder.config.cjs",
    "desktop:package:dir": "electron-builder --dir --config electron-builder.config.cjs",
    "desktop:debug": "pnpm run desktop:compile && pnpm run desktop:package:dir",
    "desktop:build": "pnpm run desktop:compile && pnpm run desktop:package",
    "test:rpc": "pnpm exec tsx desktop/main/__tests__/core-rpc-client.test.ts",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/electron": "^1.4.38",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^7.0.3",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "lucide-vue-next": "^1.0.0",
    "npm-run-all": "^4.1.5",
    "pinia": "^3.0.4",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.7",
    "wait-on": "^9.0.3"
  },
  "main": "dist-electron/main/index.js",
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  }
}

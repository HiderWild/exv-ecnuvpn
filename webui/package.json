{
  "name": "webui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "npm-run-all --parallel dev electron:dev electron:start",
    "electron:dev": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "electron:start": "wait-on http://localhost:5173 dist-electron/main/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist-electron/main/index.js",
    "build": "vue-tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "prepare:native": "node scripts/prepare-native.cjs",
    "desktop:build": "npm run build && npm run build:electron && npm run prepare:native && electron-builder",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/electron": "^1.4.38",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "autoprefixer": "^10.5.0",
    "axios": "^1.16.0",
    "cross-env": "^7.0.3",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "lucide-vue-next": "^1.0.0",
    "npm-run-all": "^4.1.5",
    "pinia": "^3.0.4",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.7",
    "wait-on": "^9.0.3"
  },
  "main": "dist-electron/main/index.js",
  "build": {
    "appId": "cn.edu.ecnu.vpn",
    "productName": "ECNU VPN",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "native/bin",
        "to": "bin",
        "filter": [
          "**/*",
          "!*.lib",
          "!*.pdb",
          "!*.exp",
          "!*.a",
          "!libssl-*.dll",
          "!libcrypto-*.dll"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "ECNU-VPN",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ECNU VPN",
      "deleteAppDataOnUninstall": false,
      "include": "build-resources/installer.nsh"
    },
    "portable": {
      "artifactName": "ECNU-VPN-${version}-portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "build-resources/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.inherit.plist",
      "artifactName": "ECNU-VPN-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}

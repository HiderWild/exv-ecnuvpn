{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "EXV_BUILD_UI_SHELL": "OFF"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows release build",
      "inherits": "release-base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-windows/cpp",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS release build",
      "inherits": "release-base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos/cpp",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux release build",
      "inherits": "release-base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux/cpp",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-release",
      "configurePreset": "windows-release"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    }
  ]
}

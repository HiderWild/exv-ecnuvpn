{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 15,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows release build",
      "description": "Configure the native Windows build under build/windows/cpp.",
      "inherits": "release-base",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/windows/cpp",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS release build",
      "description": "Configure the native macOS build under build/macos/cpp.",
      "inherits": "release-base",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/macos/cpp",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-release",
      "configurePreset": "windows-release"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}